# Syntropy Food Extension - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED FOR DEVELOPMENT
# =============================================================================

# OpenAI API Key
# Get your key from: https://platform.openai.com/api-keys
# Required for AI analysis features
OPENAI_API_KEY=sk-...

# =============================================================================
# AUTHENTICATION - Clerk + Supabase
# =============================================================================
# Clerk provides authentication with Google OAuth
# Supabase is used as the backend with Clerk JWT verification
# Docs: https://supabase.com/docs/guides/auth/third-party/clerk

# Clerk Publishable Key (safe for client-side, required)
# Get from: https://dashboard.clerk.com → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_...

# Clerk Secret Key (server-side only, keep secure!)
# Used for backend verification and user management
CLERK_SECRET_KEY=sk_test_...

# Authorized domains for Clerk authentication
# Comma-separated list of allowed redirect URLs
CLERK_AUTHORIZED_DOMAINS=http://localhost:3000,http://localhost:3005

# Supabase Configuration (for backend data storage)
# Get from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...

# =============================================================================
# OPTIONAL - API CONFIGURATION
# =============================================================================

# OpenAI Model (default: gpt-4-vision-preview)
# Options: gpt-4-vision-preview, gpt-4-turbo, gpt-4o
OPENAI_MODEL=gpt-4-vision-preview

# OpenAI Organization ID (optional)
# Only needed if you have multiple organizations
OPENAI_ORG_ID=

# =============================================================================
# OPTIONAL - FEATURE FLAGS
# =============================================================================

# Enable/disable features (true/false)
FEATURE_HOVER_CARDS=true
FEATURE_SAFETY_ALERTS=true
FEATURE_INGREDIENT_ANALYSIS=true
FEATURE_PERSONAL_INSIGHTS=true

# =============================================================================
# OPTIONAL - INTEGRATION ENDPOINTS
# =============================================================================

# FDA API Endpoint (default: https://api.fda.gov/food/enforcement.json)
FDA_API_ENDPOINT=https://api.fda.gov/food/enforcement.json

# USDA API Endpoint (default: https://www.fsis.usda.gov/fsis/api/recall)
USDA_API_ENDPOINT=https://www.fsis.usda.gov/fsis/api/recall

# DIET API (Diet Insight Engine Transformer)
# Local: http://localhost:8000
# Production: https://diet.syntropy.health (or your Railway URL)
DIET_API_URL=http://localhost:8000

# Journal API (Syntropy-Journals)
# Local: http://localhost:3000
JOURNAL_API_URL=http://localhost:3000

# OpenNutrition API (mcp-opennutrition REST service)
# Local: http://localhost:3001
OPENNUTRITION_API_URL=http://localhost:3001

# =============================================================================
# TESTING & INTEGRATION
# =============================================================================

# Enable integration tests (runs against live APIs)
INTEGRATION_TESTS=false

# API token for authenticated integration test requests
API_TOKEN=

# =============================================================================
# OPTIONAL - CACHE CONFIGURATION
# =============================================================================

# Analysis cache TTL in milliseconds (default: 3600000 = 1 hour)
CACHE_ANALYSIS_TTL=3600000

# Recalls cache TTL in milliseconds (default: 21600000 = 6 hours)
CACHE_RECALLS_TTL=21600000

# Maximum cache entries (default: 100)
CACHE_MAX_ENTRIES=100

# =============================================================================
# OPTIONAL - BRANDING & ICONS
# =============================================================================

# Extension Icon Paths (relative to public/ directory)
# These paths are used by the manifest.json and HTML files
# Default values use the icons in public/icons/

# Main logo (high resolution brand image)
ICON_LOGO=icons/syntropy.png

# Extension icons for Chrome (16x16, 48x48, 128x128)
ICON_16=icons/favicon-16x16.png
ICON_32=icons/favicon-32x32.png
ICON_48=icons/icon48.png
ICON_128=icons/icon128.png

# Favicon for HTML pages
ICON_FAVICON=icons/favicon.ico

# Banner image for promotional/about pages
ICON_BANNER=icons/Banner.png

# =============================================================================
# OPTIONAL - IMAGE PROCESSING
# =============================================================================

# Maximum images to process per product (default: 3)
IMAGE_MAX_COUNT=3

# Minimum image size in pixels (width * height) (default: 10000)
IMAGE_MIN_SIZE=10000

# Maximum image file size in bytes (default: 5242880 = 5MB)
IMAGE_MAX_FILE_SIZE=5242880

# =============================================================================
# OPTIONAL - LOGGING & DEBUGGING
# =============================================================================

# Enable debug logging (true/false)
DEBUG=false

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# =============================================================================
# PRODUCTION ONLY
# =============================================================================

# Chrome Web Store Client ID (for auto-updates)
# Get from: https://chrome.google.com/webstore/devconsole
CHROME_WEBSTORE_CLIENT_ID=

# Chrome Web Store Client Secret
CHROME_WEBSTORE_CLIENT_SECRET=

# Chrome Web Store Refresh Token
CHROME_WEBSTORE_REFRESH_TOKEN=

# Extension ID (generated after first upload)
CHROME_EXTENSION_ID=

# Analytics/Telemetry (optional)
ANALYTICS_ENABLED=false
ANALYTICS_ID=

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# =============================================================================
# NOTES
# =============================================================================
#
# - DO NOT commit .env file to version control
# - Store secrets securely (use environment variables or secret managers)
# - For production, use CI/CD secrets management
# - Rotate API keys regularly
# - Monitor API usage and costs
#
