{
  "name": "syntropy-food-extension",
  "version": "1.0.0",
  "description": "AI-powered food insights extension with ingredient analysis, safety alerts, and personalized recommendations",
  "main": "index.js",
  "scripts": {
    "dev": "webpack --mode development --watch",
    "build": "webpack --mode production",
    "prebuild": "npm run generate-icons",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:report": "vitest run --reporter=verbose && echo 'Test report complete'",
    "test:integration": "INTEGRATION_TESTS=true vitest run tests/integration/",
    "test:e2e": "npx playwright test --project=e2e",
    "fixtures:capture": "npx tsx scripts/capture-fixtures.ts",
    "lint": "eslint src --ext .ts,.tsx",
    "generate-icons": "node scripts/generate-icons.js",
    "process-manifest": "node scripts/process-manifest.js"
  },
  "keywords": [
    "chrome-extension",
    "food-safety",
    "ai",
    "nutrition",
    "ingredients"
  ],
  "author": "Syntropy Health",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sentry/browser": "^10.43.0",
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "autoprefixer": "^10.4.17",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.10.0",
    "dotenv": "^16.6.1",
    "eslint": "^8.56.0",
    "html-webpack-plugin": "^5.6.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.35",
    "postcss-loader": "^8.1.0",
    "sharp": "^0.33.5",
    "style-loader": "^3.3.4",
    "tailwindcss": "^3.4.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.75",
    "ai": "^3.0.0",
    "cheerio": "^1.0.0-rc.12",
    "openai": "^4.28.0",
    "turndown": "^7.1.3",
    "zod": "^3.22.4"
  }
}
